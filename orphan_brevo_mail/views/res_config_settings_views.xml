<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_brevo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.brevo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Brevo Email" string="Brevo Email" name="orphan_brevo_mail">
                    <block title="Brevo HTTPS API Configuration" name="brevo_config">
                        <setting id="brevo_api_key_setting"
                                 string="Brevo API Key"
                                 help="API key from Brevo dashboard - starts with xkeysib-">
                            <field name="brevo_api_key" password="True"/>
                        </setting>
                        <setting id="brevo_sender_email_setting"
                                 string="Sender Email"
                                 help="From-address for outgoing emails (must be a verified sender in Brevo)">
                            <field name="brevo_sender_email"/>
                        </setting>
                        <setting id="brevo_sender_name_setting"
                                 string="Sender Name"
                                 help="Display name shown to recipients">
                            <field name="brevo_sender_name"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
