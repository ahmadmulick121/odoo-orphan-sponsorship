<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_donor_list" model="ir.ui.view">
        <field name="name">donor.tree</field>
        <field name="model">orphan.sponsorship.donor</field>
        <field name="arch" type="xml">
            <tree string="Donors">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="state" widget="badge" decoration-success="state=='active'"/>
                <field name="orphan_count" string="Orphans Sponsored"/>
            </tree>
        </field>
    </record>

    <record id="view_donor_form" model="ir.ui.view">
        <field name="name">donor.form</field>
        <field name="model">orphan.sponsorship.donor</field>
        <field name="arch" type="xml">
            <form string="Donor">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="state" widget="badge"/>
                    </group>
                    <notebook>
                        <page string="Sponsored Orphans">
                            <field name="orphan_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="age"/>
                                    <field name="location"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_donor_list" model="ir.actions.act_window">
        <field name="name">Donors</field>
        <field name="res_model">orphan.sponsorship.donor</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
