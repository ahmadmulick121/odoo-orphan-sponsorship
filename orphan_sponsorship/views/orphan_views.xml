<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_orphan_list" model="ir.ui.view">
        <field name="name">orphan.list</field>
        <field name="model">orphan.sponsorship.orphan</field>
        <field name="arch" type="xml">
            <list string="Orphans">
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="location"/>
                <field name="status" widget="badge" decoration-success="status=='sponsored'" decoration-warning="status=='unassigned'"/>
                <field name="donor_id"/>
            </list>
        </field>
    </record>

    <record id="view_orphan_form" model="ir.ui.view">
        <field name="name">orphan.form</field>
        <field name="model">orphan.sponsorship.orphan</field>
        <field name="arch" type="xml">
            <form string="Orphan">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="location"/>
                        <field name="status" widget="badge"/>
                        <field name="donor_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_orphan_list" model="ir.actions.act_window">
        <field name="name">Orphans</field>
        <field name="res_model">orphan.sponsorship.orphan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
