<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_orphan_assigned" model="mail.template">
            <field name="name">Orphan Assignment Notification</field>
            <field name="model_id" ref="orphan_sponsorship.model_orphan_sponsorship_orphan"/>
            <field name="subject">An orphan has been assigned to your sponsorship: {{ object.name }}</field>
            <field name="email_to">{{ object.donor_id.email }}</field>
            <field name="email_from">orphan@sponsorship.com</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html"><![CDATA[
<div style="margin:0;padding:20px;background:#f4f4f4;font-family:Arial,sans-serif;">
  <div style="max-width:600px;margin:auto;background:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e0e0e0;">
    <div style="background:#1f7a5c;color:#ffffff;padding:24px 30px;">
      <h2 style="margin:0;font-size:20px;">Sponsorship Assignment Confirmation</h2>
    </div>
    <div style="padding:30px;color:#333333;font-size:14px;line-height:1.6;">
      <p>Dear <strong>{{ object.donor_id.name }}</strong>,</p>
      <p>Thank you for your generous support. We are delighted to inform you that an orphan has been assigned to your sponsorship. Here are the details:</p>
      <table style="width:100%;border-collapse:collapse;margin:16px 0;">
        <tr>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;background:#f9f9f9;width:35%;"><strong>Name</strong></td>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;">{{ object.name }}</td>
        </tr>
        <tr>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;background:#f9f9f9;"><strong>Age</strong></td>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;">{{ object.age }} years</td>
        </tr>
        <tr>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;background:#f9f9f9;"><strong>Gender</strong></td>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;">{{ object.gender | capitalize }}</td>
        </tr>
        <tr>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;background:#f9f9f9;"><strong>Location</strong></td>
          <td style="padding:8px 12px;border:1px solid #e0e0e0;">{{ object.location }}</td>
        </tr>
      </table>
      <p>Your sponsorship will make a real difference in this child's life. We will keep you updated with regular progress reports.</p>
      <p>Warm regards,<br/><strong>Orphan Sponsorship Team</strong></p>
    </div>
    <div style="background:#f9f9f9;padding:16px 30px;font-size:12px;color:#888888;border-top:1px solid #e0e0e0;">
      This is an automated notification from the Orphan Sponsorship Management System.
    </div>
  </div>
</div>
            ]]></field>
        </record>
    </data>
</odoo>
